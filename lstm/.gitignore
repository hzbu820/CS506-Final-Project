# LSTM Stock Prediction Project .gitignore

# Python virtual environment
.venv/
env/
venv/
ENV/
.env
.python-version

# Python cache files
__pycache__/
*.py[cod]
*$py.class
.cache/
.pytest_cache/
*.so

# Large model files - exclude most but include samples
outputs/models/*.pth
outputs/models/*.pkl
!outputs/models/*sample*.pth
!sample_models/*.pth

# INCLUDE most output figures and results
!outputs/figures/*.png
!outputs/ensemble_analysis/*.png
!outputs/normalized_ensemble/*.png
!outputs/multiple_runs/*.png

# Include prediction CSVs but exclude very large ones
!outputs/predictions/*.csv
!outputs/ensemble_analysis/*.csv
!outputs/normalized_ensemble/*.csv

# IDE specific files
.idea/
.vscode/
*.swp
*.swo

# OS specific files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Jupyter Notebook
.ipynb_checkpoints

# Preserving example files for documentation
!outputs/figures/example_*.png
!outputs/ensemble_analysis/example_*.png
!outputs/normalized_ensemble/example_*.png

# Ignore datasets and generated data
outputs/data/
dataset/
*.csv
!requirements.txt
!*/example_*.csv

# Keep directory structure with gitkeep files
!*/.gitkeep 